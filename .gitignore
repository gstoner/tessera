# Build artifacts
# build-asan / build-tsan / build-ubsan come from scripts/run_sanitizers.sh
build/
build-*/
cmake-build-*/
# CMake/CTest staging directories beneath tools/** (the CLI starter
# scaffold uses _build/ — keep those local artifacts out of git).
**/_build/
*.o
*.a
*.so
*.dylib
*.dll

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
.pytest_cache/
.coverage
htmlcov/

# IDEs
.vscode/
.idea/
*.swp
*.swo

# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon
._*

# Logs and databases
*.log
*.db
*.sqlite

# Temporary files
*.tmp
tmp/
temp/

# Generated files
*.inc
*.h.inc
*.cpp.inc
# ...except the Apple runtime-ops X-macro table: the Apple backend build
# #includes it and CMake does NOT generate it, so it must be committed for a
# fresh checkout to build. Drift-gated by
# tests/unit/test_apple_runtime_ops_table_in_sync.py.
!src/compiler/codegen/Tessera_Apple_Backend/include/Tessera/Target/Apple/apple_runtime_ops.inc

# CUDA
*.fatbin
*.cubin
*.ptx

# Tessera specific
.tessera_cache/
compiled_models/
performance_logs/

# Example verification outputs
examples/advanced/**/runs/

# Repo-local generated metadata/builds
python/tessera.egg-info/
research/sandbox_compilers/build/

# lit test runtime artifacts (recreated on every `lit` invocation)
tests/tessera-ir/**/Output/
tests/tessera-ir/.lit_test_times.txt
src/solvers/tpp/test/TPP/Output/
src/solvers/tpp/test/TPP/.lit_test_times.txt
src/compiler/codegen/tessera_gpu_backend_NVIDIA/test/nvidia/Output/
src/compiler/codegen/tessera_gpu_backend_NVIDIA/test/.lit_test_times.txt

# Local exact-device proof bundles (retained on the hardware host, never
# represented as source or GitHub-hosted evidence).
artifacts/

# Claude Code harness — transient scheduler / worktree / lock artifacts.
# settings.local.json is per-user and should NOT be checked in either.
.claude/*.lock
.claude/scheduled_tasks.lock
.claude/worktrees/
.claude/settings.local.json

# graphify knowledge graph — local code-intelligence artifact. Untracked
# (2026-06-08): `graphify update` only adds/updates nodes and never prunes
# deleted files, so a tracked graph goes stale on refactors and churns the
# cache dir on every run. Keep it local; regenerate via `graphify update .`.
graphify-out/

# Local Python virtualenv (scripts/setup_ubuntu.sh)
.venv/

# Stray ROCm installer artifact (do not commit)
amdgpu-install_*.deb
*.deb
