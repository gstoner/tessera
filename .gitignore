# Build artifacts
# build-asan / build-tsan / build-ubsan come from scripts/run_sanitizers.sh
build/
build-*/
cmake-build-*/
*.o
*.a
*.so
*.dylib
*.dll

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
.pytest_cache/
.coverage
htmlcov/

# IDEs
.vscode/
.idea/
*.swp
*.swo

# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon
._*

# Logs and databases
*.log
*.db
*.sqlite

# Temporary files
*.tmp
tmp/
temp/

# Generated files
*.inc
*.h.inc
*.cpp.inc

# CUDA
*.fatbin
*.cubin
*.ptx

# Tessera specific
.tessera_cache/
compiled_models/
performance_logs/

# Example verification outputs
examples/advanced/**/runs/

# Repo-local generated metadata/builds
python/tessera.egg-info/
research/sandbox_compilers/build/

# lit test runtime artifacts (recreated on every `lit` invocation)
tests/tessera-ir/**/Output/
tests/tessera-ir/.lit_test_times.txt
src/solvers/tpp/test/TPP/Output/
src/solvers/tpp/test/TPP/.lit_test_times.txt

# Claude Code harness — transient scheduler / worktree / lock artifacts.
# settings.local.json is per-user and should NOT be checked in either.
.claude/*.lock
.claude/scheduled_tasks.lock
.claude/worktrees/
.claude/settings.local.json
