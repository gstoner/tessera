import os

config.test_source_root = "@CMAKE_CURRENT_SOURCE_DIR@"
config.test_exec_root = "@CMAKE_CURRENT_BINARY_DIR@"
config.llvm_tools_dir = "@TESSERA_LLVM_TOOLS_DIR@"
config.substitutions.append(('%trop', '@TESSERA_ROCM_OPT_EXECUTABLE@'))

# Load the real test config (test_format + suffixes + PATH wiring).  Without
# this load_config the site config sets roots but lit never learns how to
# discover tests, so it reports "contained no tests".
lit_config.load_config(config, os.path.join(config.test_source_root, "lit.cfg.py"))
